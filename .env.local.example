# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only, used by /api/admin/*, /api/cron/refresh-clients,
# /api/admin/memory-health, and any other route that needs to
# bypass RLS (multi-tenant admin operations). Never commit.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── LLM ─────────────────────────────────────────────────────
# OpenAI — chat completions + embedding for the knowledge RAG
# pipeline (text-embedding-3-small).
OPENAI_API_KEY=your-openai-api-key

# Anthropic — required by the memory refresh pipeline (Claude
# Sonnet 4 synthesis in lib/memory/refresh.ts). Refresh fails
# with "ANTHROPIC_API_KEY missing" if absent.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Perplexity — chat fallback when OpenAI is down.
PPLX_API_KEY=your-perplexity-api-key

# ─── Cron / monitoring ───────────────────────────────────────
# Bearer token used by Vercel Cron to authenticate against
# /api/cron/refresh-clients. Vercel injects
# `Authorization: Bearer ${CRON_SECRET}` automatically when set.
CRON_SECRET=long-random-string

# Base URL used by Supabase auth.admin.generateLink for the
# password-recovery redirect. Should be the canonical public URL
# of the deployed app (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://your-deployed-app.example.com

# ─── SEO APIs ────────────────────────────────────────────────
# Consumed by the `run-analysis` Supabase Edge Function AND by
# the new Next.js Node route (lib/analyses/run-analysis.ts) when
# the Phase 7 flag below is on. In production these live in:
#   - Supabase Dashboard > Edge Functions > Secrets (legacy path)
#   - Vercel Project > Settings > Environment Variables (new path)
# Only set them locally if you run the analyses end-to-end in dev.
# SEMRUSH_API_KEY=
# AHREFS_API_KEY=
# GOOGLE_PSI_API_KEY=

# ─── Phase 7 — Integrations Layer migration ─────────────────
# Feature flags to toggle the call-sites that trigger the
# 9-driver analysis between the legacy Supabase Edge Function
# and the new Next.js Node route at /api/analyses/run.
# Default = unset (legacy). Set to 'true' to opt in.
#
# NEXT_PUBLIC_USE_NEXT_RUN_ANALYSIS — read by app/(dashboard)/analyzer/page.tsx
#   (browser-side trigger, manual analyses).
# USE_NEXT_RUN_ANALYSIS — read by lib/monitoring/run.ts
#   (server-side trigger, Vercel Cron).
# Keep them aligned, otherwise manual vs cron flows diverge.
# NEXT_PUBLIC_USE_NEXT_RUN_ANALYSIS=
# USE_NEXT_RUN_ANALYSIS=
