#!/usr/bin/env bash
# Wrapper bash per scripts/dataforseo-smoke.ts. Carica .env.local
# (incluse DATAFORSEO_LOGIN/DATAFORSEO_PASSWORD) e lancia tsx.
#
# Usage:
#   bash scripts/dataforseo-smoke

set -e

cd "$(dirname "$0")/.."

if [ ! -f .env.local ]; then
  echo "ERRORE: .env.local mancante."
  exit 1
fi

set -a
# shellcheck disable=SC1091
source .env.local
set +a

if [ -z "${DATAFORSEO_LOGIN:-}" ] || [ -z "${DATAFORSEO_PASSWORD:-}" ]; then
  echo "ERRORE: mancano DATAFORSEO_LOGIN o DATAFORSEO_PASSWORD in .env.local."
  echo "Aggiungili con i comandi pbpaste indicati nelle istruzioni."
  exit 1
fi

if [ -z "${NEXT_PUBLIC_SUPABASE_URL:-}" ] || [ -z "${SUPABASE_SERVICE_ROLE_KEY:-}" ]; then
  echo "ERRORE: mancano NEXT_PUBLIC_SUPABASE_URL o SUPABASE_SERVICE_ROLE_KEY in .env.local."
  exit 1
fi

echo "URL: $NEXT_PUBLIC_SUPABASE_URL"
echo "DataForSEO login: $DATAFORSEO_LOGIN"
echo "DataForSEO password: ${DATAFORSEO_PASSWORD:0:3}***"
echo

exec npx tsx scripts/dataforseo-smoke.ts
