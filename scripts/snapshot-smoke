#!/usr/bin/env bash
# Wrapper per scripts/snapshot-smoke.ts. Orchestra TUTTI i provider Phase 7B
# in parallelo (DataForSEO opzionale).
#
# Usage:
#   bash scripts/snapshot-smoke
#   DOMAIN=soloaffittipay.it bash scripts/snapshot-smoke
#   DATAFORSEO_KEYWORDS="kw1,kw2" bash scripts/snapshot-smoke

set -e
cd "$(dirname "$0")/.."

if [ ! -f .env.local ]; then
  echo "ERRORE: .env.local mancante."
  exit 1
fi

set -a
# shellcheck disable=SC1091
source .env.local
set +a

if [ -z "${NEXT_PUBLIC_SUPABASE_URL:-}" ] || [ -z "${SUPABASE_SERVICE_ROLE_KEY:-}" ]; then
  echo "ERRORE: mancano NEXT_PUBLIC_SUPABASE_URL o SUPABASE_SERVICE_ROLE_KEY in .env.local."
  exit 1
fi

exec npx tsx scripts/snapshot-smoke.ts
