#!/usr/bin/env bash
# Wrapper per scripts/wappalyzer-smoke.ts. Carica .env.local e lancia tsx.
#
# Usage:
#   bash scripts/wappalyzer-smoke
#   DOMAIN=soloaffittipay.it bash scripts/wappalyzer-smoke

set -e
cd "$(dirname "$0")/.."

if [ ! -f .env.local ]; then
  echo "ERRORE: .env.local mancante."
  exit 1
fi

set -a
# shellcheck disable=SC1091
source .env.local
set +a

if [ -z "${NEXT_PUBLIC_SUPABASE_URL:-}" ] || [ -z "${SUPABASE_SERVICE_ROLE_KEY:-}" ]; then
  echo "ERRORE: mancano NEXT_PUBLIC_SUPABASE_URL o SUPABASE_SERVICE_ROLE_KEY in .env.local."
  exit 1
fi

exec npx tsx scripts/wappalyzer-smoke.ts
