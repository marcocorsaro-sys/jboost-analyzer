#!/usr/bin/env bash
# Wrapper hardcoded per smoke Wappalyzer su jakala.com.
# Domain incluso nello script per evitare il problema macOS Smart Links
# che converte 'jakala.com' in markdown link al paste in Terminal.
#
# Usage: bash scripts/wappalyzer-jakala

set -e
cd "$(dirname "$0")/.."

if [ ! -f .env.local ]; then
  echo "ERRORE: .env.local mancante."
  exit 1
fi

set -a
# shellcheck disable=SC1091
source .env.local
set +a

export DOMAIN=jakala.com
exec npx tsx scripts/wappalyzer-smoke.ts
